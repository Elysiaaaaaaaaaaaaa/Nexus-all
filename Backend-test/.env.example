# 后端环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 运行环境 (development/production)
ENV=development

# 后端服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8003

# CORS配置 - 允许的前端来源（用逗号分隔）
# 生产环境请设置为实际的前端域名
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# 日志配置
BACKEND_LOG_LEVEL=INFO

# AI服务配置（根据实际使用的服务填写）
# OPENAI_API_KEY=your_openai_api_key
# DASHSCOPE_API_KEY=your_dashscope_api_key
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# 火山引擎方舟API配置
ARK_API_KEY=your_ark_api_key
ARK_API_TIMEOUT=60.0  # API超时时间（秒），默认60秒
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3  # API基础URL

# 文件存储配置
# USER_FILES_DIR=./user_files
# USER_AVATARS_DIR=./user_avatars
# STATIC_DIR=./static

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=img_2_video
DB_USER=img_2_video
DB_PASSWORD=n2wwaxxYejDRhGWe

# 其他配置
# MAX_UPLOAD_SIZE=5242880  # 5MB (字节)
# SESSION_TIMEOUT=3600  # 会话超时时间（秒）
